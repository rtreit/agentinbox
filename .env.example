# Required for Azure Storage Queue access
STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# GroupMe bot ID for posting replies (fallback default)
GROUPME_BOT_ID=your_default_bot_id_here

# Recommended for Windows service / Session 0 Copilot auth
# GH_TOKEN=github_pat_or_fine_grained_token_here

# Optional: GroupMe user access token for helper scripts
# GROUPME_ACCESS_TOKEN=your_groupme_access_token_here

# Per-agent bot IDs (looked up as GROUPME_BOT_ID_{AGENT_NAME_UPPER})
# GROUPME_BOT_ID_HAL=your_hal_bot_id
# GROUPME_BOT_ID_STRESSBOT=your_stressbot_bot_id
# GROUPME_BOT_ID_DEVBOT=your_devbot_bot_id

# Optional: override defaults
# AGENTINBOX_AGENT_NAME=hal
# AGENTINBOX_POLL_INTERVAL=10
# AGENTINBOX_EXECUTOR_TYPE=copilot
# AGENTINBOX_COPILOT_MODEL=claude-sonnet-4.5
# AGENTINBOX_QUEUE_NAME=agentinbox-hal
# AGENTINBOX_WORKING_DIRECTORY=.   # executor target directory (can be another repo)
# AGENTINBOX_LOG_DIR=logs
